# =========================================================================
# AccessGuard Environment Variables Configuration Example
# Copy this file to '.env' at the root of the project.
# =========================================================================

# Application General Settings
PORT=5000
NODE_ENV=development

# Database Configuration (Used by Docker services and PostgreSQL container)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=accessguard

# Complete PostgreSQL connection URL (Used directly by Prisma ORM)
# Inside Docker, the database service is named 'db'.
DATABASE_URL="postgresql://postgres:postgres_password@db:5432/accessguard?schema=public"

# Authentication Security Settings
JWT_SECRET="super-secret-jwt-key-replace-this-in-production-123456"
JWT_EXPIRE_IN="1h"
COOKIE_EXPIRE_DAYS=1
