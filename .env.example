# AccessGuard Root Environment Configuration Reference

# Backend Port
PORT=5050

# PostgreSQL Connection String (Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public)
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5433/accessguard?schema=public"

# Authentication Security Settings (Required for signing JWT tokens)
JWT_SECRET="super-secret-jwt-key-replace-this-in-production-123456"

# Token Expiry Settings
JWT_EXPIRE_IN="1h"
COOKIE_EXPIRE_DAYS=1
